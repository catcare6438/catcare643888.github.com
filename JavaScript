function decorateCalendarDay(dateStr, dayElement) {
    const dayData = getDayData(dateStr);
    const hasMyShift = dayData.some(s => s.name === "你" || s.name === "球球");
    const hasAnySchedule = dayData.length > 0;

    // 清除舊的
    const old = dayElement.querySelector('.day-status-icons');
    if(old) old.remove();

    const iconDiv = document.createElement('div');
    iconDiv.className = 'day-status-icons';
    
    // 邏輯組合
    if (hasMyShift && hasAnySchedule) {
        iconDiv.innerHTML = "<span>🐱</span><span>🔸</span>";
    } else if (hasMyShift) {
        iconDiv.innerHTML = "<span>🐱</span>";
    } else if (hasAnySchedule) {
        iconDiv.innerHTML = "<span>🔸</span>";
    } else {
        iconDiv.innerHTML = "<span>🎉</span>";
    }

    dayElement.appendChild(iconDiv);
    
    // 今日加圈圈
    const today = new Date().toISOString().split('T')[0];
    if (dateStr === today) {
        dayElement.classList.add('today-mark');
    }
}
